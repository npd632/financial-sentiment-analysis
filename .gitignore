# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Virtual Environments
.venv/
venv/
ENV/
env/
.env

# Project specific data/models exclusion (excluding large files but keeping directory placeholders)
# We track the .gitkeep files so the directory structure is maintained on Git,
# but exclude actual datasets or weights.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

models/baseline/*
!models/baseline/.gitkeep
models/finbert_finetuned/*
!models/finbert_finetuned/.gitkeep
models/price_direction/*
!models/price_direction/.gitkeep
models/price_direction_v2/*
!models/price_direction_v2/.gitkeep
models/finbert_news_adapted/*
!models/finbert_news_adapted/.gitkeep

evaluation/figures/*
!evaluation/figures/.gitkeep

